{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "loadless-wp/asset-manager",
  "version": "1.0.0",
  "title": "LoadLess WP Asset Manager",
  "category": "widgets",
  "icon": "performance",
  "description": "Display asset management information for the current page.",
  "keywords": ["assets", "scripts", "styles", "performance", "optimization"],
  "textdomain": "loadless-wp",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "postId": {
      "type": "integer",
      "default": 0
    },
    "showLink": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:../includes/class-blocks.php"
}
